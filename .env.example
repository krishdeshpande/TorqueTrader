# ─────────────────────────────────────────────────────────────────────────────
# TorqueTrader — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev (SQLite):
DATABASE_URL=sqlite:///./torque_trader.db
# Production (PostgreSQL — Render provides this automatically):
# DATABASE_URL=postgresql://user:password@host:5432/torquetrader

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=CHANGE_ME_generate_a_64_byte_random_string

# ── Redis ─────────────────────────────────────────────────────────────────────
# Leave blank to use in-memory fakeredis (dev only — state lost on restart).
# Upstash free tier: https://upstash.com
# REDIS_URL=redis://:password@host.upstash.io:6379

# ── Email OTP (Resend) ────────────────────────────────────────────────────────
# Free tier: 3,000 emails/month. Sign up at https://resend.com
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OTP_FROM_EMAIL=noreply@yourdomain.com

# ── Cloudflare R2 (File Storage) ─────────────────────────────────────────────
# Free tier: 10 GB storage, 1M reads/month.
# Get credentials at: https://dash.cloudflare.com → R2 → Manage API Tokens
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key
# R2_SECRET_ACCESS_KEY=your_r2_secret_key
# R2_PUBLIC_BUCKET=torquetrader-public
# R2_PRIVATE_BUCKET=torquetrader-private

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Use * for dev only.
ALLOWED_ORIGINS=*
# Production example:
# ALLOWED_ORIGINS=https://www.torquetrader.in,https://app.torquetrader.in
